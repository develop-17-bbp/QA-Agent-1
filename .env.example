# Optional: override browser User-Agent for health crawls (some hosts block non-browser UAs).
# QA_AGENT_USER_AGENT=Mozilla/5.0 ...

# Optional: PageSpeed Insights API (`qa-agent health --pagespeed`). Enable "PageSpeed Insights API" in Google Cloud.
# PAGESPEED_API_KEY=

# Legacy `qa-agent run` (form tests) — optional SMTP
# Comma-separated list (overrides defaultNotify.emails in config when set)
# QA_AGENT_NOTIFY_EMAILS=team@our-org.com,product@our-org.com

# Optional SMTP — when set with EMAIL_FROM, run emails HTML + text report
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM="QA Agent <qa-agent@our-org.com>"
