# Comma-separated list (overrides defaultNotify.emails in config when set)
# QA_AGENT_NOTIFY_EMAILS=team@company.com,product@company.com

# Optional SMTP — when set with EMAIL_FROM, run emails HTML + text report
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM="QA Agent <qa-agent@yourcompany.com>"
