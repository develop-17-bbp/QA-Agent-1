# =============================================================================
# Google API keys (different Google products — do not mix them up)
# =============================================================================

# --- PageSpeed Insights API (optional) — used with `qa-agent health --pagespeed`
# Enable "PageSpeed Insights API" in Google Cloud; lab scores like pagespeed.web.dev.
# https://developers.google.com/speed/docs/insights/v5/get-started
#
# Preferred variable name (first match wins in code):
#   PAGESPEED_API_KEY
# Aliases (same key type; use only one active value to avoid confusion):
#   GOOGLE_PAGESPEED_API_KEY
#   GOOGLE_API_KEY
# PAGESPEED_API_KEY=

# --- Chrome UX Report (optional) — real-user Web Vitals from Chrome users
# Unlike PageSpeed (lab), CrUX reports the 75th-percentile experience of
# real users over the last 28 days. Enable "Chrome UX Report API" in
# Google Cloud. GOOGLE_API_KEY can be reused as a fallback.
# CRUX_API_KEY=
#
# Shortcut: if you've already enabled "Chrome UX Report API" on the SAME GCP
# project that hosts PageSpeed Insights, you can reuse PAGESPEED_API_KEY by
# setting the flag below — no need to generate a second key.
# REUSE_PAGESPEED_KEY_FOR_CRUX=true

# =============================================================================
# Google Search Console + Google Analytics 4 (optional) — real first-party data
# =============================================================================
# When configured, QA-Agent can overlay REAL impressions, clicks, average SERP
# position from GSC and REAL sessions, users, page views from GA4 on top of the
# scraped DuckDuckGo data. This closes the "no absolute numbers" gap for the
# user's own verified properties at zero marginal cost.
#
# Setup:
#   1. Go to https://console.cloud.google.com/apis/credentials and create an
#      OAuth 2.0 Client ID of type "Web application".
#   2. Authorized redirect URI must be (exactly): http://localhost:3847/api/auth/google/callback
#      If you run on a custom port, use that port and update QA_AGENT_PORT below.
#   3. Enable "Google Search Console API" and "Google Analytics Data API" for
#      the project on the API library page.
#   4. Paste the client ID and secret below and restart the server.
#   5. Visit http://localhost:3847/google-connections and click "Connect with Google".
#
# Tokens are persisted to data/google-tokens.json (gitignored, mode 0o600).
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# =============================================================================
# Google Ads API (optional) — real search volume + CPC + competition data
# =============================================================================
# Powers the Keyword Impact page and Keyword Overview volume/CPC numbers.
# Unlike the GSC/GA4 OAuth above, Google Ads uses a SEPARATE OAuth client +
# developer token + manager customer ID. All three are required.
#
# Setup:
#   1. Apply for a Google Ads developer token at
#      https://ads.google.com/home/tools/manager-accounts/ (Basic access is free
#      but takes 1-3 business days for approval).
#   2. Create a Google Ads OAuth 2.0 Client ID at
#      https://console.cloud.google.com/apis/credentials (type: Web application).
#      Authorized redirect URI must be (exactly):
#        http://localhost:3847/api/auth/gads/callback
#      (Override via GOOGLE_ADS_REDIRECT_URI if you run a custom port.)
#   3. Enable "Google Ads API" in the API library.
#   4. Paste client ID + secret + developer token below.
#   5. Visit /google-connections → Connect Google Ads → grant adwords scope.
#      The refresh token is written back to GOOGLE_ADS_REFRESH_TOKEN at runtime.
#   6. CUSTOMER_ID = the 10-digit Ads account ID you want to query (no dashes).
#      LOGIN_CUSTOMER_ID = the MCC / manager account ID if the above is under
#      one (optional; defaults to CUSTOMER_ID when omitted).
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_REFRESH_TOKEN=
# GOOGLE_ADS_REDIRECT_URI=http://localhost:3847/api/auth/gads/callback
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CUSTOMER_ID=
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# =============================================================================
# Bing Webmaster Tools (optional) — real inbound links + anchor text for own verified site
# =============================================================================
# Sign up at https://www.bing.com/webmasters/ → add + verify your site (DNS / XML file / meta tag).
# Then Settings → API Access → generate an API key. Free tier. Covers ~40-60% of Ahrefs
# backlink coverage for the verified site.
# BING_WEBMASTER_API_KEY=

# =============================================================================
# OpenPageRank (optional) — free domain authority 0-10 score
# =============================================================================
# 1000 requests/day free tier. Sign up at https://www.domcop.com/openpagerank/
# → request a free API key (instant). Powers the Domain Authority card on
# Backlinks + Dashboard. Any of the three variable names below works (first
# non-empty wins); OPR_API_KEY is the canonical one.
# OPR_API_KEY=
# OPEN_PAGERANK_API_KEY=
# OPEN_PAGE_RANK_API_KEY=

# =============================================================================
# URLScan.io (optional) — Brand Monitor + recent scan intelligence
# =============================================================================
# Works anonymously but heavily rate-limited. A free key lifts the limits and
# unlocks better Brand Monitor coverage. Sign up at https://urlscan.io/user/signup
# → user settings → API Keys → generate. Free tier: 100 public scans/day.
# URLSCAN_API_KEY=

# =============================================================================
# Cloudflare Radar (optional) — real domain traffic rank in Cloudflare dataset
# =============================================================================
# Free Cloudflare API token with "Account:Radar:Read" scope. Powers the domain
# rank signal on the Competitive Estimator. Sign up at https://dash.cloudflare.com
# → My Profile → API Tokens → Create Token → custom token → Account:Radar:Read.
# Either variable works (first non-empty wins):
# CLOUDFLARE_API_TOKEN=
# CF_API_TOKEN=

# =============================================================================
# Ollama (local LLM — required for agentic pipeline, zero API cost)
# =============================================================================
# QA-Agent uses Ollama as its sole LLM backend (Gemini was removed in v1.0).
# Install from https://ollama.com — recommended: llama3.2 (8GB GPU sufficient)
#   ollama pull llama3.2
#   ollama serve
# The agentic pipeline (SERP analysis, smart crawl planning, AI summaries,
# dashboard "Ask about this run") sends all prompts here.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# Per-request timeout in ms (default 60000). Raise for slower hardware / bigger models.
# OLLAMA_REQUEST_TIMEOUT_MS=60000

# =============================================================================
# Local dashboard (`npm start` / `qa-agent health --serve`)
# =============================================================================

# HTTP port (default 3847). If you see EADDRINUSE, another instance is still bound — run: npm run dashboard:kill
# QA_AGENT_PORT=3847

# =============================================================================
# Health crawl tuning (optional)
# =============================================================================

# How many sites to crawl at once (health). Default 4; set 1 for sequential. CLI: --concurrency
# QA_AGENT_SITE_CONCURRENCY=4

# Speed (large uncapped crawls): more parallel HTTP per site — try 24–32 on a fast network (watch for rate limits / timeouts).
# QA_AGENT_FETCH_CONCURRENCY=16

# Fewer retries = faster when many URLs fail (1–5, default 3).
# QA_AGENT_FETCH_MAX_ATTEMPTS=2

# Milliseconds between retry backoff steps (default 100).
# QA_AGENT_FETCH_RETRY_BACKOFF_MS=100

# Optional: override browser User-Agent for health crawls (some hosts block non-browser UAs).
# QA_AGENT_USER_AGENT=Mozilla/5.0 ...

# Max wait (ms) for each PageSpeed API HTTP response (CLI: --pagespeed-timeout-ms). Does not change Lighthouse’s internal page load limits.
# QA_AGENT_PAGESPEED_TIMEOUT_MS=120000

# Parallel PageSpeed / viewport API calls (when those flags are on)
# QA_AGENT_PAGESPEED_CONCURRENCY=3
# QA_AGENT_VIEWPORT_CONCURRENCY=2

# --- Start-page screenshots (Playwright) — wait for real content before PNG
# Navigation wait: load (default), domcontentloaded, or networkidle
# QA_AGENT_SCREENSHOT_WAIT_UNTIL=load
# Max ms to wait for visible text/media/layout after navigation (1000–120000; default scales off request timeout)
# QA_AGENT_SCREENSHOT_CONTENT_TIMEOUT_MS=12000
# PC capture: full-page height, viewport size
# QA_AGENT_SCREENSHOT_FULL_PAGE=1
# QA_AGENT_SCREENSHOT_WIDTH=1440
# QA_AGENT_SCREENSHOT_HEIGHT=900

# =============================================================================
# Daily SEO report (n8n integration — see docs/N8N-Integration-Guide.md)
# =============================================================================
# Bearer token protecting POST /api/daily-report — leave empty for local dev;
# set to a long random string in production so random callers can't kick off
# crawls. Generate one with:  `openssl rand -hex 32`  or  `node -e 'console.log(require("crypto").randomBytes(32).toString("hex"))'`
# DAILY_REPORT_TOKEN=

# Default sites for the CLI fallback `tsx scripts/daily-report.ts` when no
# --sites flag is passed. Comma-separated.
# DAILY_REPORT_SITES=https://www.example.com/

# Optional: when the CLI runs, POST the generated report to this webhook (n8n
# / Zapier / Make.com inbound URL). Skip if you call /api/daily-report from
# n8n directly.
# DAILY_REPORT_WEBHOOK=https://n8n.your-co.com/webhook/seo-daily

# =============================================================================
# Legacy `qa-agent run` (form tests) — optional SMTP
# =============================================================================

# Comma-separated list (overrides defaultNotify.emails in config when set)
# QA_AGENT_NOTIFY_EMAILS=team@our-org.com,product@our-org.com

# Optional SMTP — when set with EMAIL_FROM, run emails HTML + text report
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM="QA Agent <qa-agent@our-org.com>"
