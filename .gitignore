# Dependencies & build
node_modules/
dist/
web/dist/
*.tsbuildinfo

# Env and local config (never commit secrets or your URL lists)
.env
.env.*
!.env.example
config/urls.txt
config/sites.json

# Google OAuth tokens (GSC + GA4 integration) — contains refresh_token, never commit
data/google-tokens.json

# GSC Links CSV imports — per-domain cache of parsed Search Console Links exports
data/gsc-links/

# Position-tracking history — tracked pairs + daily snapshots (local state)
data/position-history/
data/tracked-pairs.json

# QA-Agent outputs
artifacts/*
!artifacts/.gitkeep
playwright-report/
test-results/

# Fixture site (local dev for `npm run fixture`)
fixture-site/node_modules/
fixture-site/data/submissions.json

# OS & editors
.DS_Store
.idea/
.vscode/

# Cursor (optional — uncomment if you want these ignored repo-wide)
# .cursorignore
# .cursorindexingignore
