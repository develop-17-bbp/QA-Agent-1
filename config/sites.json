{
  "defaultNotify": {
    "emails": ["josh@doctusweb.com"]
  },
  "sites": [
    {
      "id": "local-fixture-homepage",
      "name": "Local fixture — homepage contact (run fixture-site first)",
      "enabled": true,
      "url": "http://127.0.0.1:3333/",
      "forms": [
        {
          "selector": "form#fixture-contact-form",
          "fields": [
            {
              "name": "name",
              "selector": "input#name",
              "value": "QA Agent (fixture run)",
              "action": "fill"
            },
            {
              "name": "email",
              "selector": "input#email",
              "value": "qa-agent@example.test",
              "action": "fill"
            },
            {
              "name": "company",
              "selector": "input#company",
              "value": "Internal QA",
              "action": "fill"
            },
            {
              "name": "message",
              "selector": "textarea#message",
              "value": "Automated submission from QA-Agent fixture site.",
              "action": "fill"
            }
          ],
          "submit": {
            "selector": "button[type=\"submit\"]"
          }
        }
      ],
      "success": {
        "type": "url_contains",
        "value": "thanks.html"
      },
      "notify": {
        "emails": ["product@doctusweb.com"]
      }
    },
    {
      "id": "realdrseattle-home-contact",
      "name": "realdrseattle® — homepage consultation form (production)",
      "enabled": false,
      "url": "https://realdrseattle.com/",
      "forms": [
        {
          "selector": "form#email-form",
          "fields": [
            {
              "name": "name",
              "selector": "input#name-2",
              "value": "QA Agent (automated test)",
              "action": "fill"
            },
            {
              "name": "email",
              "selector": "[id=\"name-company.com\"]",
              "value": "qa+smoke@doctusweb.com",
              "action": "fill"
            },
            {
              "name": "message",
              "selector": "textarea#field",
              "value": "Automated smoke test from QA-Agent — please ignore.",
              "action": "fill"
            }
          ],
          "submit": {
            "selector": "input[type=\"submit\"].submit-button"
          }
        }
      ],
      "success": {
        "type": "selector_visible",
        "selector": ".w-form:has(#email-form) .w-form-done",
        "timeoutMs": 30000
      },
      "notify": {
        "emails": ["owner@doctusweb.com"]
      }
    }
  ]
}
