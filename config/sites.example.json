{
  "defaultNotify": {
    "emails": ["product@our-org.com"]
  },
  "sites": [
    {
      "id": "example-contact",
      "name": "Example — contact form",
      "enabled": false,
      "url": "https://example.com/contact",
      "forms": [
        {
          "selector": "form#contact",
          "fields": [
            {
              "name": "name",
              "selector": "input[name=\"name\"]",
              "value": "QA Agent Test",
              "action": "fill"
            },
            {
              "name": "email",
              "selector": "input[name=\"email\"]",
              "value": "qa+test@our-org.com",
              "action": "fill"
            },
            {
              "name": "message",
              "selector": "textarea[name=\"message\"]",
              "value": "Automated smoke submission.",
              "action": "fill"
            }
          ],
          "submit": { "selector": "button[type=\"submit\"]" }
        }
      ],
      "success": {
        "type": "url_contains",
        "value": "thank"
      },
      "notify": {
        "emails": ["owner@our-org.com"]
      }
    },
    {
      "id": "example-homepage-embed",
      "name": "Example — contact block on homepage (same URL, form below the fold)",
      "enabled": false,
      "url": "https://example.com/",
      "forms": [
        {
          "selector": "section#contact form, .contact-section form, [data-testid=\"contact-form\"]",
          "fields": [
            {
              "name": "name",
              "selector": "input[name=\"name\"], input[placeholder*=\"Your name\" i]",
              "value": "QA Agent Test",
              "action": "fill"
            },
            {
              "name": "email",
              "selector": "input[type=\"email\"], input[name=\"email\"]",
              "value": "qa+test@our-org.com",
              "action": "fill"
            },
            {
              "name": "message",
              "selector": "textarea",
              "value": "Automated smoke submission.",
              "action": "fill"
            }
          ],
          "submit": {
            "selector": "button[type=\"submit\"], button:has-text(\"Submit your request\")"
          }
        }
      ],
      "success": {
        "type": "text_visible",
        "value": "Thank you"
      }
    },
    {
      "id": "local-fixture-homepage",
      "name": "Local fixture — run `npm run fixture` first, then enable this site",
      "enabled": false,
      "url": "http://127.0.0.1:3333/",
      "forms": [
        {
          "selector": "form#fixture-contact-form",
          "fields": [
            {
              "name": "name",
              "selector": "input#name",
              "value": "QA Agent (fixture run)",
              "action": "fill"
            },
            {
              "name": "email",
              "selector": "input#email",
              "value": "qa-agent@example.test",
              "action": "fill"
            },
            {
              "name": "company",
              "selector": "input#company",
              "value": "Internal QA",
              "action": "fill"
            },
            {
              "name": "message",
              "selector": "textarea#message",
              "value": "Automated submission from QA-Agent fixture site.",
              "action": "fill"
            }
          ],
          "submit": {
            "selector": "button[type=\"submit\"]"
          }
        }
      ],
      "success": {
        "type": "url_contains",
        "value": "thanks.html"
      }
    }
  ]
}
