{
  "name": "qa-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Config-driven browser form checks across many sites, with reports and optional email",
  "bin": {
    "qa-agent": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "run": "node dist/index.js run",
    "dev": "tsx src/index.ts run",
    "lint": "tsc --noEmit",
    "fixture": "npm start --prefix fixture-site"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "nodemailer": "^6.10.0",
    "p-limit": "^6.2.0",
    "playwright": "^1.51.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.17",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
